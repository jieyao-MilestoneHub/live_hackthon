# Base URL of the Editor API (backend-api). Baked in at build time.
# AWS dev backend (Lambda + API Gateway; App Runner was SCP-blocked).
# Override to http://localhost:8080 for local backend dev.
NEXT_PUBLIC_API_BASE_URL=https://3xgcvbiz3j.execute-api.us-east-1.amazonaws.com

# Amazon Cognito login (USER_PASSWORD_AUTH via plain fetch — no AWS SDK).
# Login is OPTIONAL for the demo; when a user logs in, the IdToken is attached
# as `Authorization: Bearer <token>` on every API call.
NEXT_PUBLIC_COGNITO_CLIENT_ID=6qhvnefntmdpk8o0l6a3492lhd
NEXT_PUBLIC_COGNITO_REGION=us-east-1
