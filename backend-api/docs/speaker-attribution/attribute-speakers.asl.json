{
  "Comment": "Analysis & Composition Workflow 片段：在 NormalizeTranscript 與 DetectHighlights 之間插入具名說話者歸屬。待 infra orchestration 模組落地後接上。Transcribe 無 .sync 整合，故以 waitForTaskToken 等待完成，再由 AttributeSpeakers（light Lambda，跑 analysis.attribution.pipeline.run_attribution）產出 attributed_transcript.v1。",
  "_fragment_states": {
    "StartTranscription": {
      "Type": "Task",
      "Comment": "StartTranscriptionJob(ShowSpeakerLabels=true, MaxSpeakerLabels); EventBridge 完成 → SendTaskSuccess(token)",
      "Resource": "arn:aws:states:::lambda:invoke.waitForTaskToken",
      "Parameters": {
        "FunctionName": "${StartTranscribeFn}",
        "Payload": { "project_id.$": "$.project_id", "media_uri.$": "$.media_uri", "task_token.$": "$$.Task.Token" }
      },
      "Next": "NormalizeTranscript"
    },
    "NormalizeTranscript": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Parameters": { "FunctionName": "${NormalizeFn}", "Payload.$": "$" },
      "ResultPath": "$.transcript",
      "Next": "AttributeSpeakers"
    },
    "AttributeSpeakers": {
      "Type": "Task",
      "Comment": "run_attribution：Rekognition FaceSearch + ASD + fusion + Nova 複核 → attributed_transcript.v1（寫 work bucket）",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Parameters": {
        "FunctionName": "${AttributeSpeakersFn}",
        "Payload": { "project_id.$": "$.project_id", "media_uri.$": "$.media_uri" }
      },
      "ResultPath": "$.attributed_transcript",
      "Retry": [{ "ErrorEquals": ["States.TaskFailed"], "IntervalSeconds": 5, "MaxAttempts": 2, "BackoffRate": 2.0 }],
      "Next": "DetectHighlights"
    },
    "DetectHighlights": {
      "Type": "Task",
      "Comment": "既有高光偵測（可選擇消費 attributed_transcript 的角色資訊）",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Parameters": { "FunctionName": "${DetectHighlightsFn}", "Payload.$": "$" },
      "End": true
    }
  }
}
