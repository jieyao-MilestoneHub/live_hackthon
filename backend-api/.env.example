# Copy to .env for local runs. Points the app at the shared contracts dir.
CONTRACTS_DIR=../contracts
AWS_REGION=us-east-1
ANALYSIS_ENGINE=rule

# --- M1 Editor API ---
ENV=dev
# In-memory stores by default so local uvicorn / pytest run with no AWS creds.
# Set USE_INMEMORY=0 to hit real DynamoDB / S3 (or moto in tests).
USE_INMEMORY=1
DYNAMODB_TABLE=VideoEditor
RAW_BUCKET=video-editor-raw-dev
WORK_BUCKET=video-editor-work-dev
OUTPUT_BUCKET=video-editor-output-dev
PRESIGN_EXPIRY_SEC=900
