{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://live-hackthon/contracts/highlights.v1.schema.json",
  "title": "highlights.v1",
  "description": "高光分析輸出（Analysis Worker → Composer / 編輯器的介面契約）。M1 Project/毫秒版：project_id、highlight_id、時間一律毫秒（ms，影片相對）、含 source_duration_ms 與 suggested_title。對應 issue #6。聊天優先分析流程 additive 演化：新增 signal / status / chat_window / correction / emotion 拆解 / detection / description / provenance 皆為 optional，既有 highlight_id/start_ms/end_ms/score 語意與 timeline.v1 join 不變。",
  "type": "object",
  "required": ["schema_version", "project_id", "source_duration_ms", "highlights"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "highlights.v1" },
    "project_id": { "type": "string" },
    "source_duration_ms": { "type": "integer", "minimum": 0, "description": "原始影片長度（毫秒）" },
    "analysis_version": { "type": "string", "description": "分析模型/規則版本，如 highlight-rule-1.0.0" },
    "parameters": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "max_clips": { "type": "integer", "minimum": 1 },
        "min_duration_ms": { "type": "integer", "minimum": 0 },
        "max_duration_ms": { "type": "integer", "minimum": 0 },
        "padding_before_ms": { "type": "integer", "minimum": 0, "default": 0 },
        "padding_after_ms": { "type": "integer", "minimum": 0, "default": 0 }
      }
    },
    "highlights": {
      "type": "array",
      "items": { "$ref": "#/$defs/highlight" }
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "highlight": {
      "type": "object",
      "required": ["highlight_id", "start_ms", "end_ms", "score"],
      "additionalProperties": false,
      "properties": {
        "highlight_id": { "type": "string", "description": "project 內唯一" },
        "start_ms": { "type": "integer", "minimum": 0, "description": "原始影片中的起點（毫秒，影片相對）；聊天優先流程中為修正後的『事件窗』起點" },
        "end_ms": { "type": "integer", "minimum": 0, "description": "原始影片中的終點（毫秒，影片相對）；聊天優先流程中為修正後的『事件窗』終點" },
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "reason": { "type": "string", "description": "此片段被選為高光的原因" },
        "transcript": { "type": "string", "description": "此片段對應的逐字內容" },
        "suggested_title": { "type": "string", "description": "AI 建議的短片標題" },
        "source_segment_ids": { "type": "array", "items": { "type": "string" } },
        "selected": { "type": "boolean", "description": "編輯器：是否被選入草稿（預設由 Composer 決定）" },
        "locked": { "type": "boolean", "description": "編輯器：使用者是否鎖定此片段（重新組片時不得移除）" },
        "signal": {
          "type": "string",
          "enum": ["chat_volume", "speech_emotion", "fusion"],
          "description": "偵測來源訊號：chat_volume=聊天量熱區（聊天優先預設）/ speech_emotion=逐字稿情緒 / fusion=融合"
        },
        "status": {
          "type": "string",
          "enum": ["candidate", "included", "excluded", "shifted"],
          "default": "candidate",
          "description": "產出結果：candidate=初篩候選 / included=納入 / excluded=如純開場白被排除 / shifted=事件窗相對聊天窗有位移"
        },
        "excluded_reason": { "type": ["string", "null"], "description": "status=excluded 時的原因（如：僅為開場自我介紹，非真正橋段）" },
        "description": { "type": ["string", "null"], "description": "深層脈絡（此橋段具體在幹嘛），供理解『為什麼好笑』" },
        "chat_window": {
          "type": "object",
          "additionalProperties": false,
          "description": "原始『聊天熱區』偵測窗（影片相對毫秒，已由 epoch 換算）；start_ms/end_ms 則為修正後事件窗",
          "properties": {
            "start_ms": { "type": "integer", "minimum": 0 },
            "end_ms": { "type": "integer", "minimum": 0 }
          }
        },
        "correction": {
          "type": "object",
          "additionalProperties": false,
          "description": "聊天窗 → 事件窗 的人工/AI 修正（觀眾反應落後 chat lag）",
          "properties": {
            "applied": { "type": "boolean", "default": false },
            "offset_ms": { "type": "integer", "description": "事件窗相對聊天窗位移；往前抓為負（如 -20000）、延後為正" },
            "corrected_by": { "type": ["string", "null"] },
            "corrected_at": { "type": ["string", "null"], "format": "date-time" },
            "note": { "type": ["string", "null"] }
          }
        },
        "emotion": {
          "type": "object",
          "additionalProperties": false,
          "description": "Level-1 情緒分數與分項拆解（非只有單一 score）",
          "required": ["score"],
          "properties": {
            "score": { "type": "number", "minimum": 0, "maximum": 1 },
            "breakdown": {
              "type": "object",
              "additionalProperties": false,
              "description": "各面向對 score 的貢獻",
              "properties": {
                "keyword": { "type": "number", "minimum": 0 },
                "emoji": { "type": "number", "minimum": 0 },
                "punctuation": { "type": "number", "minimum": 0 },
                "volume": { "type": "number", "minimum": 0 }
              }
            },
            "counts": {
              "type": "object",
              "additionalProperties": true,
              "description": "原始計數（keyword / emoji / 驚嘆號 / 訊息量等）"
            }
          }
        },
        "detection": {
          "type": "object",
          "additionalProperties": true,
          "description": "chat_volume 偵測數學（mean+1σ 熱區），供可解釋性",
          "properties": {
            "minute_volume": { "type": "integer", "minimum": 0 },
            "baseline_mean": { "type": "number" },
            "baseline_sigma": { "type": "number" },
            "threshold": { "type": "number" }
          }
        },
        "provenance": {
          "type": "object",
          "additionalProperties": true,
          "description": "跨層溯源（偵測→修正→標註 的來歷），比照 attributed_transcript 的 evidence 慣例"
        }
      }
    }
  }
}
