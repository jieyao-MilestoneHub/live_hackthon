{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://live-hackthon/contracts/subtitle.v1.schema.json",
  "title": "subtitle.v1",
  "description": "動態字幕計畫（Creative Planning Worker 輸出，供 FFmpeg 燒字幕）。時間一律毫秒（ms）。另會伴隨產出 subtitle.vtt / subtitle-style.json，見 demand.md §十二。",
  "type": "object",
  "required": ["schema_version", "language", "cues"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "subtitle.v1" },
    "language": { "type": "string", "description": "BCP-47，如 zh-TW" },
    "project_id": { "type": "string" },
    "render_id": { "type": "string" },
    "style": { "type": "object", "additionalProperties": true, "description": "字體/大小/顏色/位置等樣式，對應 subtitle-style.json" },
    "cues": {
      "type": "array",
      "items": { "$ref": "#/$defs/cue" }
    }
  },
  "$defs": {
    "cue": {
      "type": "object",
      "required": ["start_ms", "end_ms", "text"],
      "additionalProperties": false,
      "properties": {
        "start_ms": { "type": "integer", "minimum": 0 },
        "end_ms": { "type": "integer", "minimum": 0 },
        "text": { "type": "string" },
        "emphasis_words": { "type": "array", "items": { "type": "string" }, "description": "需強調/動畫呈現的關鍵詞" }
      }
    }
  }
}
