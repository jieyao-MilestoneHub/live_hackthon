{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://live-hackthon/contracts/transcript.v1.schema.json",
  "title": "transcript.v1",
  "description": "正規化逐字稿格式（分析 pipeline 的 Normalize Transcript 輸出；Analysis Worker 的輸入契約）。M1 Project/毫秒版：以 project_id 為鍵、時間一律毫秒（ms）。對應 issue #4。",
  "type": "object",
  "required": ["schema_version", "project_id", "language_code", "duration_ms", "segments"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "transcript.v1" },
    "project_id": { "type": "string" },
    "language_code": { "type": "string", "description": "BCP-47，如 zh-TW" },
    "duration_ms": { "type": "integer", "minimum": 0, "description": "原始影片長度（毫秒）" },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "bucket": { "type": "string" },
        "key": { "type": "string" },
        "version_id": { "type": "string" }
      }
    },
    "segments": {
      "type": "array",
      "items": { "$ref": "#/$defs/segment" }
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "segment": {
      "type": "object",
      "required": ["segment_id", "start_ms", "end_ms", "text"],
      "additionalProperties": false,
      "properties": {
        "segment_id": { "type": "string" },
        "start_ms": { "type": "integer", "minimum": 0 },
        "end_ms": { "type": "integer", "minimum": 0 },
        "speaker": { "type": ["string", "null"] },
        "text": { "type": "string" },
        "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "text"],
            "additionalProperties": false,
            "properties": {
              "type": { "type": "string", "enum": ["pronunciation", "punctuation"] },
              "start_ms": { "type": ["integer", "null"], "minimum": 0 },
              "end_ms": { "type": ["integer", "null"], "minimum": 0 },
              "text": { "type": "string" },
              "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
            }
          }
        }
      }
    }
  }
}
