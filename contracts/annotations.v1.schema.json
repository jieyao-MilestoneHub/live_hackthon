{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://live-hackthon/contracts/annotations.v1.schema.json",
  "title": "annotations.v1",
  "description": "高光的結構化編輯註記（衍生自 highlights.v1，以 highlight_id 關聯；不改動 highlights，比照 attributed_transcript.v1 的 additive 慣例）。含 5 維度標註（埋梗/反應-一開始/反應-轉折/笑點爆點/聊天室精彩留言）與敘事節拍 cut-list（台詞/時間碼/長度）。此層位於 timeline.v1（跨片段扁平化 EDL）之上，為組片輸入，非同一物件。時間一律影片相對毫秒（ms）。",
  "type": "object",
  "required": ["schema_version", "project_id", "annotations"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "annotations.v1" },
    "project_id": { "type": "string" },
    "annotation_version": {
      "type": ["string", "null"],
      "description": "標註引擎/規則版本，如 annotation-1.0.0"
    },
    "annotations": {
      "type": "array",
      "items": { "$ref": "#/$defs/annotation" }
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "annotation": {
      "type": "object",
      "required": ["highlight_id", "dimensions"],
      "additionalProperties": false,
      "properties": {
        "highlight_id": { "type": "string", "description": "對應 highlights.v1 的 highlight_id（join key）" },
        "title": { "type": ["string", "null"] },
        "description": {
          "type": ["string", "null"],
          "description": "深層脈絡（此橋段具體在幹嘛），如『端午節粽子開箱—試吃冰的無調味豆沙減重粽：猶豫抗拒→以為會甜→其實很怪→表情失控』"
        },
        "dimensions": {
          "type": "array",
          "description": "5 維度標註 span（以絕對影片相對毫秒表示起訖）",
          "items": { "$ref": "#/$defs/dimension_span" }
        },
        "beats": {
          "type": "array",
          "description": "敘事節拍 cut-list（埋梗→反應→笑點），每刀台詞/時間碼/長度；供 composer 組出 timeline clips",
          "items": { "$ref": "#/$defs/beat" }
        },
        "corrected_by": { "type": ["string", "null"], "description": "user id（若被人工更正）" },
        "corrected_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "dimension_span": {
      "type": "object",
      "required": ["dimension", "start_ms", "end_ms"],
      "additionalProperties": false,
      "properties": {
        "dimension": {
          "type": "string",
          "enum": ["setup", "reaction_start", "reaction_turn", "punchline", "chat_highlights"],
          "description": "埋梗=setup / 反應-一開始=reaction_start / 反應-轉折=reaction_turn / 笑點爆點=punchline / 聊天室精彩留言=chat_highlights"
        },
        "start_ms": { "type": "integer", "minimum": 0, "description": "絕對影片相對毫秒（起）" },
        "end_ms": { "type": "integer", "minimum": 0, "description": "絕對影片相對毫秒（訖）" },
        "text": { "type": ["string", "null"], "description": "該維度的標註文字/台詞說明" },
        "messages": {
          "type": ["array", "null"],
          "description": "chat_highlights 維度專用：挑選的聊天室精彩留言（可引用 chatlog.v1 的 message_id）",
          "items": {
            "type": "object",
            "required": ["text"],
            "additionalProperties": false,
            "properties": {
              "message_id": { "type": ["string", "null"] },
              "username": { "type": ["string", "null"] },
              "text": { "type": "string" }
            }
          }
        }
      }
    },
    "beat": {
      "type": "object",
      "required": ["order", "start_ms", "end_ms"],
      "additionalProperties": false,
      "properties": {
        "order": { "type": "integer", "minimum": 1, "description": "1-based 節拍播放順序" },
        "beat": {
          "type": ["string", "null"],
          "enum": ["setup", "reaction_start", "reaction_turn", "punchline", null],
          "description": "節拍類型（對應維度枚舉；閒聊過場可為 null）"
        },
        "line": { "type": ["string", "null"], "description": "此刀的台詞" },
        "start_ms": { "type": "integer", "minimum": 0, "description": "影片相對毫秒（起）" },
        "end_ms": { "type": "integer", "minimum": 0, "description": "影片相對毫秒（訖）" },
        "duration_ms": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "= end_ms − start_ms（冗餘便利欄）"
        }
      }
    }
  }
}
